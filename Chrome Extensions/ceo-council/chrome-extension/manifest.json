{
  "manifest_version": 3,
  "name": "CEO Council — оценка сайтов",
  "version": "1.0",
  "description": "Оценка сайтов через скилл CEO Council: три мнения (Джобс, Цукерберг, Лебедев) на русском",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:3001/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
